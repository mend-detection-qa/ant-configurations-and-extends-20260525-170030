# Unified Agent configuration for Ant+Ivy resolution.
# Without these flags the UA Ant resolver falls back to Mode 3
# (binary file path scan) and emits zero deps for a manifest-only probe.
# Mode 1 (Ivy resolution via ivy.xml + ivysettings.xml) only fires when
# both flags below are true. See whitesource/unified-agent
# .claude/knowledge/resolvers/java-jvm.md  3 Ant Resolver.
#
# This probe targets configuration-mapping (#6) and configuration-extends (#7).
# The ivy.xml declares five configurations (compile, runtime, test, provided, master)
# with an extends chain: test->runtime->compile. Varied conf-mapping syntax is
# exercised across the five dependencies.

ant.resolveDependencies=true
ant.ivyResolveDependencies=true

# Resolve all declared configurations. Empty = none ignored.
ant.ivyIgnoredConfigurations=

# Do not exclude source files from fingerprinting (probe ships no Java sources).
ant.ignoreSourceFiles=false
